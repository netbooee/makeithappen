# Copy to .env.local and fill in. All are optional — without them the app
# runs in local demo mode (seeded data, localStorage persistence).

# Supabase (enables Google sign-in + cloud preference sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Claude API (enables real AI assistant + email drafting)
# Without it, the assistant answers from your local data and email
# drafts use a built-in template.
VITE_ANTHROPIC_API_KEY=
